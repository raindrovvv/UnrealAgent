<!-- 컨텍스트 사용률 미터입니다. -->
<div class="relative group cursor-help ml-1">
    <div class="flex items-center gap-2 bg-transparent px-2 py-1 rounded-sm border border-transparent hover:bg-[#1a1a1a] hover:border-[#333] transition-all duration-200">
        <div class="flex flex-col gap-0.5 w-24">
            <div class="flex justify-between items-center text-[9px] text-[#777] font-sans leading-none font-medium uppercase tracking-widest">
                <span class="text-[8px]">Context</span>
                <span class="@PercentColorClass font-bold @PercentAnimClass">@($"{UsagePercent:F0}%")</span>
            </div>
            <div class="h-0.5 w-full bg-[#2a2a2a] rounded-sm overflow-hidden">
                <div class="h-full @BarColorClass rounded-sm opacity-90 @BarShadowClass transition-all duration-500"
                     style="width: @($"{UsagePercent:F0}%")"></div>
            </div>
        </div>
    </div>

    <!-- 호버 툴팁입니다. -->
    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-64 p-3 bg-[#111] border border-[#333] rounded shadow-2xl text-[10px] opacity-0 group-hover:opacity-100 transition-all duration-200 pointer-events-none z-50 transform translate-y-2 group-hover:translate-y-0">
        <div class="space-y-1.5 font-mono text-[#aaa]">
            <!-- 시스템 프롬프트입니다. -->
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#555]"></span>
                    <span>System</span>
                </div>
                <span class="text-[#666]">@FormatTokensWithPct(Usage?.SystemPrompt ?? 0)</span>
            </div>

            <!-- UNREALAGENT.md입니다. -->
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#4a9ec9]"></span>
                    <span>UNREALAGENT.md</span>
                </div>
                <span class="text-[#666]">@FormatTokensWithPct(Usage?.UnrealAgentMd ?? 0)</span>
            </div>

            <!-- 스킬 목록입니다. -->
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#a78bfa]"></span>
                    <span>Skills</span>
                </div>
                <span class="text-[#666]">@FormatTokensWithPct(Usage?.Skills ?? 0)</span>
            </div>

            <!-- 도구 정의입니다. -->
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#d68a51]"></span>
                    <span>Tools</span>
                </div>
                <span class="text-[#666]">@FormatTokensWithPct(Usage?.Tools ?? 0)</span>
            </div>

            <!-- 대화 히스토리입니다. -->
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#e5c07b]"></span>
                    <span>Messages</span>
                </div>
                <span class="text-[#666]">@FormatTokensWithPct(Usage?.Messages ?? 0)</span>
            </div>

            <div class="h-px bg-[#222] my-1"></div>

            <!-- 남은 공간입니다. -->
            <div class="flex justify-between text-[#e0e0e0] font-bold">
                <span>Available</span>
                <span class="text-[#4ba96c]">@FormatTokensWithPct(Usage?.FreeSpace ?? 0)</span>
            </div>
        </div>
        <div class="absolute bottom-[-5px] left-1/2 -translate-x-1/2 w-2.5 h-2.5 bg-[#111] border-b border-r border-[#333] rotate-45"></div>
    </div>
</div>
