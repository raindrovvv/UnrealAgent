<!-- Effort 레벨 선택 버튼입니다. -->
<div class="flex items-center gap-2 relative">
    <span class="text-[9px] uppercase font-bold tracking-wider @EffortLabelClass transition-colors">Effort</span>
    <div class="flex bg-[#0f0f0f] rounded p-0.5 border border-[#333]">
        @foreach (var Level in Levels)
        {
            var bIsSelected = Settings.Effort == Level.Value;
            <button @onclick="() => SelectEffort(Level.Value)"
                    class="relative group/btn px-1.5 py-0.5 rounded-[1px] text-[9px] transition-colors @(bIsSelected ? "font-bold bg-[#0070e0] text-white shadow-sm ring-1 ring-white/10" : "font-medium text-[#555] hover:text-[#ccc] hover:bg-[#222]")">
                @Level.Label
                <!-- 툴팁입니다. -->
                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-40 p-2 bg-[#151515]/90 backdrop-blur-md border border-[#333] rounded shadow-xl text-[10px] ue-tooltip z-50 whitespace-normal text-left">
                    <span class="text-[#e0e0e0] font-bold block mb-0.5 uppercase tracking-wide text-[9px]">@Level.Label Effort</span>
                    <span class="text-[#aaa] leading-tight block">@Level.Description</span>
                    <div class="absolute bottom-[-5px] left-1/2 -translate-x-1/2 w-2 h-2 bg-[#151515]/90 border-b border-r border-[#333] rotate-45"></div>
                </div>
            </button>
        }
    </div>
</div>