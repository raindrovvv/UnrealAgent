@if (ImageBase64 is not null)
{
    <!-- 첨부 이미지 미리보기입니다. -->
    <div class="px-3 pt-3 pb-1">
        <div class="inline-flex items-center gap-2 bg-[#222] pl-1 pr-2 py-1 rounded border border-[#333] hover:border-[#555] transition-colors">
            <div class="w-5 h-5 rounded-sm bg-[#333] overflow-hidden flex-shrink-0 border border-white/5">
                <img src="data:@ImageMediaType;base64,@ImageBase64" class="w-full h-full object-cover" alt="" />
            </div>
            <span class="text-[10px] font-bold text-[#e0e0e0]">이미지 첨부됨</span>
            <button type="button"
                    @onclick="OnRemove"
                    class="ml-1 p-0.5 rounded hover:bg-[#333] text-[#666] hover:text-[#e05e5e] transition-colors">
                <span class="material-symbols-outlined text-[12px]">close</span>
            </button>
        </div>
    </div>
}
